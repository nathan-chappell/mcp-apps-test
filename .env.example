OPENAI_API_KEY=
CLERK_SECRET_KEY=
CLERK_OAUTH_CLIENT_ID=
CLERK_OAUTH_CLIENT_SECRET=
APP_SIGNING_SECRET=
APP_BASE_URL=http://localhost:8000
CLERK_ISSUER_URL=https://your-auth-server.example.com

# Optional overrides
CLERK_ACTIVE_METADATA_KEY=active
CLERK_ROLE_METADATA_KEY=role
DATABASE_URL=sqlite+aiosqlite:///./.local/openai-vectorstore-mcp-app.db
MCP_REQUIRED_SCOPES=
OPENAI_AGENT_MODEL=gpt-5.4
OPENAI_BRANCHING_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
OPENAI_FILE_SEARCH_MAX_RESULTS=5
OPENAI_POLL_INTERVAL_MS=1000
UPLOAD_SESSION_MAX_AGE_SECONDS=900
ASSET_DOWNLOAD_SESSION_MAX_AGE_SECONDS=900
LOG_LEVEL=INFO
